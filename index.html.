
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Primera Comunión - Daniel Santiago</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Great+Vibes&family=Montserrat:wght@300;400;600&family=Playfair+Display:italic,wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-green: #5a6e5a;
            --gold-accent: #b08d57;
            --cream-bg: #f9f7f2;
        }

        html, body {
            overflow-x: hidden;
            width: 100%;
            background-color: var(--cream-bg);
            scroll-behavior: smooth;
        }
        
        body {
            font-family: 'Montserrat', sans-serif;
            color: #4a4a4a;
            -webkit-font-smoothing: antialiased;
        }

        .font-serif-elegant { font-family: 'Cinzel', serif; }
        .font-cursive { font-family: 'Great Vibes', cursive; }
        .font-classic { font-family: 'Playfair Display', serif; }
        
        .watercolor-canvas {
            background-color: var(--cream-bg);
            background-image: url('https://www.transparenttextures.com/patterns/paper-fibers.png');
            min-height: 100vh;
            width: 100%;
            position: relative;
            padding-bottom: 50px;
            z-index: 1;
        }

        #sparkles-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .sparkle {
            position: absolute;
            background: radial-gradient(circle, #fff 10%, var(--gold-accent) 40%, transparent 100%);
            border-radius: 50%;
            opacity: 0;
            animation: twinkle var(--duration) infinite ease-in-out;
        }

        @keyframes twinkle {
            0% { opacity: 0; transform: scale(0.3) translateY(0); }
            50% { opacity: 0.8; transform: scale(1) translateY(-20px); }
            100% { opacity: 0; transform: scale(0.3) translateY(-40px); }
        }

        .botanical-header {
            width: 100%;
            height: 180px;
            background-image: url('https://www.transparentpng.com/download/watercolor-leaves/watercolor-leaves-transparent-images-12.png');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: top center;
            opacity: 0.6;
            transform: scaleY(-1);
        }

        .botanical-footer {
            width: 100%;
            height: 150px;
            background-image: url('https://www.transparentpng.com/download/watercolor-leaves/watercolor-leaves-transparent-images-12.png');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: bottom center;
            opacity: 0.6;
            margin-top: -30px;
        }

        .main-illustration {
            width: 85%;
            max-width: 300px;
            border-radius: 150px 150px 20px 20px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            border: 8px solid white;
            margin: -40px auto 30px;
            overflow: hidden;
            background: #fff;
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 1.2s cubic-bezier(0.17, 0.55, 0.55, 1);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        .btn-gold {
            background-color: transparent;
            color: var(--gold-accent);
            border: 1px solid var(--gold-accent);
            border-radius: 50px;
            padding: 10px 25px;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            transition: all 0.3s;
        }
        .btn-gold:hover {
            background: var(--gold-accent);
            color: white;
        }

        .card {
            background: white;
            border-radius: 30px;
            padding: 35px 25px;
            border: 1px solid rgba(0,0,0,0.03);
            box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        }

        /* Estilo unificado para logos de pie de página */
        .footer-logo-container {
            filter: grayscale(100%);
            opacity: 0.45;
            transition: all 0.5s ease;
        }
        .footer-logo-container:hover {
            filter: grayscale(0%);
            opacity: 0.9;
        }

        .logo-alfredo {
            height: 48px;
            width: auto;
        }
        .logo-copymax {
            height: 24px;
            width: auto;
        }
        .logo-pixelar {
            height: 38px; /* Pixelar necesita más altura para ser legible */
            width: auto;
        }

        .professional-credits {
            border-top: 1px solid rgba(0,0,0,0.05);
            padding-top: 50px;
            margin-top: 40px;
            width: 100%;
            max-width: 340px;
        }
    </style>
</head>
<body>

    <div id="sparkles-container"></div>

    <div class="watercolor-canvas">
        <div class="botanical-header"></div>

        <div class="relative z-10 flex flex-col items-center px-6">
            
            <!-- Título Principal -->
            <div class="text-center mt-[-40px] mb-8">
                <img src="imagen/copa.png" alt="Cáliz" class="w-20 mx-auto mb-4 drop-shadow-md">
                <p class="font-cursive text-4xl text-[#b08d57] mb-2">Mi Primera</p>
                <p class="font-serif-elegant text-2xl tracking-[0.2em] text-gray-700 uppercase">Comunión</p>
                
                <div class="flex items-center justify-center gap-4 my-4">
                    <div class="h-[1px] w-12 bg-[#b08d57]/30"></div>
                    <span class="text-[#b08d57] text-xs">🕊️</span>
                    <div class="h-[1px] w-12 bg-[#b08d57]/30"></div>
                </div>
            </div>

            <!-- ILUSTRACIÓN DEL NIÑO -->
            <div class="main-illustration">
                <img src="imagen/rezando.jpg" alt="Daniel Santiago" class="w-full h-full object-cover">
            </div>

            <!-- Nombre -->
            <div class="text-center mb-8 reveal active">
                <h1 class="font-cursive text-6xl text-gray-800">Daniel Santiago</h1>
                <p class="font-serif-elegant text-sm tracking-[0.4em] text-gray-500 mt-2 uppercase">Luévano Soto</p>
            </div>

            <!-- CUENTA REGRESIVA -->
            <div class="w-full max-w-sm mb-12 reveal">
                <div class="text-center mb-4">
                    <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[#b08d57]">Falta muy poco:</p>
                </div>
                <div class="flex justify-center gap-3">
                    <div class="countdown-box text-center">
                        <span id="days" class="block font-serif-elegant text-xl text-gray-800">00</span>
                        <span class="text-[8px] uppercase text-gray-400">Días</span>
                    </div>
                    <div class="countdown-box text-center">
                        <span id="hours" class="block font-serif-elegant text-xl text-gray-800">00</span>
                        <span class="text-[8px] uppercase text-gray-400">Horas</span>
                    </div>
                    <div class="countdown-box text-center">
                        <span id="minutes" class="block font-serif-elegant text-xl text-gray-800">00</span>
                        <span class="text-[8px] uppercase text-gray-400">Min</span>
                    </div>
                    <div class="countdown-box text-center">
                        <span id="seconds" class="block font-serif-elegant text-xl text-gray-800">00</span>
                        <span class="text-[8px] uppercase text-gray-400">Seg</span>
                    </div>
                </div>
            </div>

            <!-- Datos del Evento -->
            <div class="w-full max-w-sm space-y-8 mb-16 reveal">
                <div class="text-center py-8 border-y border-[#e5e0d5]">
                    <div class="flex justify-around items-center">
                        <div class="text-right">
                            <p class="text-[10px] font-bold uppercase tracking-widest text-[#b08d57]">Junio</p>
                            <p class="text-xs text-gray-400 uppercase">Sábado</p>
                        </div>
                        <div class="text-5xl font-serif-elegant text-gray-800">06</div>
                        <div class="text-left">
                            <p class="text-[10px] font-bold uppercase tracking-widest text-[#b08d57]">2026</p>
                            <p class="text-xs text-gray-400 uppercase">1:00 PM</p>
                        </div>
                    </div>
                </div>

                <div class="card text-center shadow-sm">
                    <div class="flex justify-center mb-4 text-[#b08d57]">
                        <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18" /><path d="M19 21v-4a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v4" /><path d="M9 21v-4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4" /><path d="M12 2v2" /><path d="M12 7V5" /><path d="M10 7h4" /><path d="m12 7-9 5v9" /><path d="m12 7 9 5v9" /></svg>
                    </div>
                    <h4 class="font-serif-elegant text-[#b08d57] text-xs tracking-widest mb-3 uppercase">La Ceremonia</h4>
                    <p class="font-bold text-gray-700 text-sm">Parroquia de Nuestra Señora de los Dolores</p>
                    <p class="text-[11px] text-gray-500 mt-2 italic">Av. Convención 1914 poniente, Barrio de San Marcos</p>
                    <p class="text-[#5a6e5a] font-bold text-xs mt-4 uppercase tracking-widest">1:00 PM</p>
                    <a href="https://maps.app.goo.gl/uXpX9Mv6kQjU8XvP7" target="_blank" class="mt-6 inline-block btn-gold">Ver Mapa</a>
                </div>

                <div class="card text-center shadow-sm">
                    <div class="flex justify-center mb-4 text-[#b08d57]">
                        <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    </div>
                    <h4 class="font-serif-elegant text-[#b08d57] text-xs tracking-widest mb-3 uppercase">La Recepción</h4>
                    <p class="font-bold text-gray-700 text-sm">Hotel Marriott Aguascalientes</p>
                    <p class="text-[11px] text-gray-500 mt-2 italic">Blvd. a Zacatecas 402, Las Trojes</p>
                    <p class="text-[#5a6e5a] font-bold text-xs mt-4 uppercase tracking-widest">3:00 PM</p>
                    <a href="https://maps.app.goo.gl/S1S4fW3G8z9R9L6T6" target="_blank" class="mt-6 inline-block btn-gold">Ver Mapa</a>
                </div>
            </div>

            <!-- RSVP -->
            <section id="rsvp-section" class="w-full max-w-sm mb-12 reveal">
                <div class="bg-white rounded-[40px] p-10 shadow-2xl shadow-stone-200/50 border border-stone-100">
                    <div class="text-center mb-8">
                        <h3 class="text-2xl font-serif-elegant text-gray-800">Confirmación</h3>
                        <p class="text-[9px] uppercase tracking-[0.3em] text-[#5a6e5a] font-bold mt-2">Favor de confirmar antes del 23 de Mayo</p>
                    </div>
                    <div id="step-form" class="space-y-4">
                        <input type="text" id="guestName" class="w-full p-4 bg-stone-50 border-none rounded-2xl text-sm focus:ring-1 focus:ring-[#b08d57] outline-none" placeholder="Nombre o Familia">
                        <select id="guestCount" class="w-full p-4 bg-stone-50 border-none rounded-2xl text-sm outline-none">
                            <option value="1">1 Persona</option><option value="2">2 Personas</option><option value="3">3 Personas</option><option value="4">4 Personas</option><option value="5">5 Personas</option>
                        </select>
                        <button onclick="previewConfirmation()" class="w-full bg-[#5a6e5a] text-white font-bold py-4 rounded-2xl uppercase text-[10px] tracking-widest mt-2 transition-all active:scale-95">Confirmar Asistencia</button>
                    </div>
                    <div id="step-preview" class="hidden space-y-6">
                        <div class="bg-stone-50 p-6 rounded-3xl"><p id="previewText" class="text-[12px] text-gray-600 italic text-center"></p></div>
                        <button onclick="sendToWhatsApp()" class="w-full bg-[#25D366] text-white font-bold py-4 rounded-2xl uppercase text-xs tracking-widest flex items-center justify-center gap-2">Enviar WhatsApp</button>
                    </div>
                </div>
            </section>

            <!-- PIE DE PÁGINA PROFESIONAL -->
            <section class="professional-credits reveal">
                <div class="text-center space-y-8 footer-logo-container">
                    <!-- Firma Personal Alfredo Vázquez -->
                    <div class="space-y-2">
                        <p class="text-[8px] uppercase tracking-[0.4em] text-gray-400 font-semibold">Creative Design by</p>
                        <img src="imagen/lógico.png" alt="Alfredo Vázquez Logo" class="logo-alfredo">
                    </div>

                    <!-- Divisor sutil -->
                    <div class="flex items-center justify-center gap-4">
                        <div class="h-[0.5px] w-10 bg-gray-200"></div>
                        <span class="text-[10px] text-gray-300">✧</span>
                        <div class="h-[0.5px] w-10 bg-gray-200"></div>
                    </div>

                    <!-- Logos de Colaboración Proporcionales -->
                    <div class="flex items-center justify-center gap-10">
                        <img src="imagen/copymax.png" alt="Copy Max" class="logo-copymax">
                        <img src="imagen/pixelar.png" alt="PixelAR" class="logo-pixelar">
                    </div>

                    <!-- Dedicatoria final -->
                    <p class="text-[7px] uppercase tracking-[0.6em] text-gray-300 pt-6 border-t border-gray-50">
                        Exclusivo para Daniel Santiago · 2026
                    </p>
                </div>
            </section>

            <div class="botanical-footer"></div>
        </div>
    </div>

    <script>
        function createSparkles() {
            const container = document.getElementById('sparkles-container');
            for (let i = 0; i < 15; i++) {
                const sparkle = document.createElement('div');
                sparkle.className = 'sparkle';
                const size = Math.random() * 3 + 2;
                sparkle.style.width = `${size}px`;
                sparkle.style.height = `${size}px`;
                sparkle.style.left = `${Math.random() * 100}%`;
                sparkle.style.top = `${Math.random() * 100}%`;
                sparkle.style.setProperty('--duration', `${Math.random() * 4 + 3}s`);
                sparkle.style.animationDelay = `${Math.random() * 5}s`;
                container.appendChild(sparkle);
            }
        }

        const targetDate = new Date("June 6, 2026 13:00:00").getTime();
        function updateCountdown() {
            const now = new Date().getTime();
            const gap = targetDate - now;
            const second = 1000, minute = second * 60, hour = minute * 60, day = hour * 24;
            const d = Math.floor(gap / day), h = Math.floor((gap % day) / hour), m = Math.floor((gap % hour) / minute), s = Math.floor((gap % minute) / second);
            document.getElementById('days').innerText = d < 10 ? '0'+d : d;
            document.getElementById('hours').innerText = h < 10 ? '0'+h : h;
            document.getElementById('minutes').innerText = m < 10 ? '0'+m : m;
            document.getElementById('seconds').innerText = s < 10 ? '0'+s : s;
        }

        setInterval(updateCountdown, 1000);

        function previewConfirmation() {
            const nombre = document.getElementById('guestName').value.trim();
            const cantidad = document.getElementById('guestCount').value;
            if (!nombre) { document.getElementById('guestName').style.border = "1px solid #b08d57"; return; }
            const finalMessage = `🕊️ *Confirmación: Primera Comunión*\nInvitado: *${nombre}*\nPases: *${cantidad}*\n\n¡Ahí nos vemos para celebrar con Daniel Santiago!`;
            document.getElementById('previewText').innerText = finalMessage.replace(/\*/g, '');
            document.getElementById('step-form').classList.add('hidden');
            document.getElementById('step-preview').classList.remove('hidden');
            window.lastMessage = finalMessage;
        }

        function sendToWhatsApp() {
            window.open(`https://wa.me/5214498040411?text=${encodeURIComponent(window.lastMessage)}`, '_blank');
        }

        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                if (elementTop < windowHeight - 100) reveals[i].classList.add("active");
            }
        }

        window.addEventListener("scroll", reveal);
        window.onload = function() {
            reveal();
            createSparkles();
            updateCountdown();
        };
    </script>
</body>
</html>

